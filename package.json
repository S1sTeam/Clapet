{
  "name": "clapet",
  "version": "0.2.0",
  "description": "Clapet - a Claude desktop pet",
  "author": "S1sTeam",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.clapet.app",
    "productName": "Clapet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${env.ARCH}.${ext}"
    },
    "nsis": {
      "oneClick": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${env.ARCH}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${env.ARCH}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "keyspy": "^1.1.1"
  }
}
