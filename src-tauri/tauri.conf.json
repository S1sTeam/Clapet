{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Clapet",
  "version": "0.2.0",
  "identifier": "com.clapet.app",
  "build": {
    "frontendDist": "../dist-renderer",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:react",
    "beforeBuildCommand": "npm run build:react"
  },
  "app": {
    "windows": [
      {
        "title": "Clapet",
        "width": 876,
        "height": 574,
        "minWidth": 320,
        "minHeight": 300,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icon.ico",
      "../build/icon.png",
      "../build/icon.icns"
    ]
  }
}
